# ⚠️ Valores solo para desarrollo local. En producción:
#   - Genera secretos JWT aleatorios: `openssl rand -base64 48`
#   - Usa credenciales S3/DB reales y NO las subas al repositorio.
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://dental:dental@localhost:5432/dental
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=dental-media
S3_ACCESS_KEY=dentalminio
S3_SECRET_KEY=dentalminio
S3_FORCE_PATH_STYLE=true
CORS_ORIGIN=http://localhost:5173
